{
  "name": "obhelper",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-first CLI scaffold for extracting web content into Obsidian markdown files",
  "type": "module",
  "bin": {
    "obhelper": "dist/cli.js"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist coverage",
    "dev": "tsx src/cli.ts",
    "postinstall": "node ./scripts/postinstall-playwright.mjs",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e:x": "node ./scripts/e2e-x.mjs",
    "verify": "npm run lint && npm run typecheck && npm run test:coverage",
    "ci": "./scripts/ci.sh"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.51.1",
    "turndown": "^7.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@types/turndown": "^5.0.5",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.18.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
